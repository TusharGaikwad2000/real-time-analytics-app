	"item": [
		{
			"name": "Ingestion",
			"item": [
				{
					"name": "Ingest Single Event",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"userId\": \"u123\",\n    \"platform\": \"amazon\",\n    \"action\": \"purchase\",\n    \"amount\": 499,\n    \"timestamp\": 1710000000\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/events",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"events"
							]
						}
					},
					"response": []
				},
				{
					"name": "Ingest Bulk Events",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "[\n    {\n        \"userId\": \"u123\",\n        \"platform\": \"amazon\",\n        \"action\": \"purchase\",\n        \"amount\": 499,\n        \"timestamp\": 1710000000\n    },\n    {\n        \"userId\": \"u456\",\n        \"platform\": \"ebay\",\n        \"action\": \"view\",\n        \"amount\": 0,\n        \"timestamp\": 1710000001\n    }\n]",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/events/bulk",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"events",
								"bulk"
							]
						}
					},
					"response": []
				}
			]
		},
		{
